{
  "name": "two-way-mirror",
  "displayName": "Two-Way Mirror",
  "description": "Split-pane AI coding assistant with a live reviewer",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmyjshang/two-way-mirror.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "twoWayMirror.open",
        "title": "Two-Way Mirror: Open"
      },
      {
        "command": "twoWayMirror.configurePlugins",
        "title": "Two-Way Mirror: Configure Plugins"
      }
    ],
    "keybindings": [
      {
        "command": "twoWayMirror.open",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "Two-Way Mirror",
      "properties": {
        "twoWayMirror.paneA": {
          "type": "string",
          "default": "",
          "enum": ["", "claude", "echo"],
          "enumDescriptions": [
            "Not configured — will prompt on first open",
            "Claude Code (full AI session)",
            "Echo (simple shell, no AI)"
          ],
          "description": "Plugin for Pane A"
        },
        "twoWayMirror.paneB": {
          "type": "string",
          "default": "",
          "enum": ["", "claude", "observer", "echo"],
          "enumDescriptions": [
            "Not configured — will prompt on first open",
            "Claude Code (reviewer / second opinion)",
            "Observer (read-only activity log)",
            "Echo (simple shell, no AI)"
          ],
          "description": "Plugin for Pane B"
        }
      }
    }
  },
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jimmyjshang/two-way-mirror/issues"
  },
  "homepage": "https://github.com/jimmyjshang/two-way-mirror#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85"
  }
}
